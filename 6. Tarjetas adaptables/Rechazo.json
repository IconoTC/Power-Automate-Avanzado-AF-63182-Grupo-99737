{
  "type": "AdaptiveCard",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.5",
  "body": [
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "Image",
              "url": "https://adaptivecards.io/content/x-red.png",
              "size": "Small"
            }
          ]
        },
        {
          "type": "Column",
          "width": "stretch",
          "verticalContentAlignment": "Center",
          "items": [
            {
              "type": "TextBlock",
              "text": "Gasto rechazado",
              "weight": "Bolder",
              "size": "Large",
              "color": "Attention"
            }
          ]
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "Tu solicitud de gasto no ha sido aprobada.",
      "wrap": true,
      "spacing": "Medium"
    },
    {
      "type": "FactSet",
      "facts": [
        { "title": "Solicitante:", "value": "${solicitante}" },
        { "title": "Concepto:", "value": "${concepto}" },
        { "title": "Importe:", "value": "${importe} €" },
        { "title": "Fecha del gasto:", "value": "${fecha}" },
        { "title": "Rechazado por:", "value": "${aprobador}" },
        { "title": "Fecha de rechazo:", "value": "${fechaRechazo}" }
      ]
    },
    {
      "type": "Container",
      "style": "attention",
      "spacing": "Medium",
      "items": [
        {
          "type": "TextBlock",
          "text": "Motivo del rechazo:",
          "weight": "Bolder",
          "size": "Small"
        },
        {
          "type": "TextBlock",
          "text": "${motivoRechazo}",
          "wrap": true
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "Modificar y volver a enviar",
      "url": "${urlEdicion}"
    },
    {
      "type": "Action.OpenUrl",
      "title": "Ver detalle del gasto",
      "url": "${urlDetalle}"
    }
  ]
}